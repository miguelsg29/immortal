<!-- Watches window changes (to sync the quick-button cluster with the system top bar) and
     hosts the phone-remote input surfaces. flagRetrieveInteractiveWindows + window content
     are needed for getWindows() and reading the focused field for text entry.
     canPerformGestures lets the remote's touchpad dispatch taps/swipes (the reboot-proof,
     no-INJECT_EVENTS way to drive any app on this touchscreen). -->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowsChanged"
    android:accessibilityFlags="flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:canPerformGestures="true"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:notificationTimeout="0"
    android:description="@string/bar_watch_desc" />

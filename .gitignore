# MkDocs build output (the docs site is built and deployed by CI, not committed).
/site

# Release signing — NEVER commit these. Back them up securely; the same key must
# sign every Immortal release for in-place self-update to work.
keystore.properties
*.jks
*.keystore

# Built APKs / staged release artifacts and scratch screenshots.
provisioning/apks/*.apk
_chk*.png

# Per-device fleet inventory written by `provision.sh --fleet`. Contains each
# device's agent auth TOKEN — never commit (the repo is public).
provisioning/fleet/

# Internal strategy/planning notes — never publish.
_planning/

# Reverse-engineering research — never publish (repo is public). Decompilation
# working dir and APKs pulled off the device. Keep internal findings in
# apk_work/ or _planning/ — NOT in docs/, which is now the published wiki source.
apk_work/
system_services.apk
*.apk

.claude/
